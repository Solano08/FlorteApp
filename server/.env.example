# Servidor
PORT=4000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# Base de datos
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=florte_app

# JWT
JWT_ACCESS_SECRET=your-access-secret
JWT_REFRESH_SECRET=your-refresh-secret

# Cloudinary (obligatorio en producción para avatares, feed, historias)
# Crear cuenta gratis en https://cloudinary.com
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Recuperación de contraseña (SMTP). En producción es obligatorio para enviar el enlace al correo.
# Gmail: usa una "contraseña de aplicación" en la cuenta de Google.
# SMTP_SECURE=true suele usarse con puerto 465; con 587 déjalo en false.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
# Remitente visible (ej: FlorteApp <no-reply@tudominio.com>). Si se omite, se usa SMTP_USER.
SMTP_FROM=
